{
  "name": "ki-web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "bundle": "esbuild src/demos/ki-frame-demo.ts --bundle --outfile=docs/ki-frame-demo.js --platform=browser --target=es2019",
    "build": "npm run lint && npm run typecheck && npm run bundle && npm run format",
    "dev": "tsc -w -p .",
    "format": "prettier --write .",
    "lint": "eslint",
    "test": "vitest",
    "test-console": "vitest --disableConsoleIntercept=false"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/jsdom": "^27.0.0",
    "@types/react": "^19.2.7",
    "csstype": "^3.2.3",
    "esbuild": "0.27.0",
    "eslint": "10.1.0",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.4.0",
    "jiti": "2.6.1",
    "jsdom": "^27.2.0",
    "prettier": "3.8.1",
    "rimraf": "6.1.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.2",
    "vitest": "3.2.4"
  }
}
